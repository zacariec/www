---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { NeuralBlobNet } from '@/components/organisms/neural-blob-net';
import PostList from '@/components/astro/PostList.astro';
import BlogHeader from '@/components/astro/BlogHeader.astro';
import { getAllPosts, getSiteConfig } from '@/lib/sanity/fetch';
import { blogIndexJsonLd } from '@/lib/seo/jsonld';
import { pickOgImage } from '@/lib/seo/og-image';

const [posts, config] = await Promise.all([getAllPosts(), getSiteConfig()]);

const mappedPosts = posts.map((p) => ({
  slug: p.slug,
  title: p.title,
  subtitle: p.subtitle,
  date: p.date,
  readingTime: p.readingTime,
  commentCount: p.commentCount,
}));

const jsonLd = blogIndexJsonLd(config);
const og = pickOgImage(undefined, config);
---

<SiteLayout
  canonicalUrl="/blog"
  description="Long-form writing on code, systems, and the patterns behind how things work."
  jsonLd={jsonLd}
  ogImage={og?.url}
  ogImageAlt={og?.alt}
  ogImageHeight={og?.height}
  ogImageWidth={og?.width}
  title="Writing"
>
  <div>
    <div class="relative h-[30vh] md:h-[40vh] overflow-hidden">
      <NeuralBlobNet client:only="react" nodeCount={mappedPosts.length} />
    </div>
    <div class="px-5 md:px-16 pt-8 md:pt-16 pb-20 md:pb-32">
      <BlogHeader />
      <div class="mt-16 md:mt-24">
        <PostList posts={mappedPosts} variant="full" />
      </div>
    </div>
  </div>
</SiteLayout>
