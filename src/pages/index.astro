---
import SiteLayout from '../layouts/SiteLayout.astro';
import HeroSection from '@/components/astro/HeroSection.astro';
import HomeThoughts from '@/components/astro/HomeThoughts.astro';
import SessionList from '@/components/astro/SessionList.astro';
import Marquee from '@/components/astro/Marquee.astro';
import { NeuralBlobNet } from '@/components/organisms/neural-blob-net';
import { getLatestSessions, getLatestTimeline, getSiteConfig } from '@/lib/sanity/fetch';
import { homeJsonLd } from '@/lib/seo/jsonld';
import { pickOgImage } from '@/lib/seo/og-image';

const [latestSessions, latestThoughts, config] = await Promise.all([
  getLatestSessions(),
  getLatestTimeline(),
  getSiteConfig(),
]);

const sessions = latestSessions.map((s) => ({
  slug: s.slug,
  title: s.title,
  subtitle: s.subtitle,
  date: s.date,
  readingTime: s.readingTime,
}));

const hasHeroImage = !!config.heroImage?.url;
const heroAlt = config.heroImage?.alt || 'Neural pathways';
const heroCaption = config.heroImage?.caption || 'Fig 01 — Neural pathways';

const jsonLd = homeJsonLd(config);
const og = pickOgImage(undefined, config);
---

<SiteLayout
  canonicalUrl="/"
  jsonLd={jsonLd}
  ogImage={og?.url}
  ogImageAlt={og?.alt}
  ogImageHeight={og?.height}
  ogImageWidth={og?.width}
>
  <div>
    <HeroSection
      description={config.heroDescription}
      heading={config.heroHeading}
      subtitle={config.heroSubtitle}
    />

    <!-- Featured Image -->
    <section class="md:px-16 pb-16 md:pb-24">
      <div class={`overflow-hidden h-[60vh] md:h-[80vh] relative ${hasHeroImage ? 'bg-[#f4f4f2]' : ''}`}>
        {hasHeroImage ? (
          <div class="absolute inset-0">
            <img
              src={config.heroImage?.url ?? ''}
              alt={heroAlt}
              class="object-cover mix-blend-multiply opacity-85 w-full h-full"
              loading="eager"
            />
            <div class="absolute inset-0 bg-white mix-blend-saturation"></div>
          </div>
        ) : (
          <NeuralBlobNet client:only="react" nodeCount={latestSessions.length + latestThoughts.length} />
        )}
      </div>
      <p class="text-[9px] tracking-[1.5px] uppercase text-[#777777] mt-4 px-5 md:px-0 font-[family-name:var(--font-space-grotesk)]">
        {heroCaption}
      </p>
    </section>

    <!-- Latest Sessions + Recent Thoughts -->
    <div class="px-5 md:px-16 pb-20 md:pb-32 flex flex-col md:flex-row gap-16 md:gap-20">
      <section class="flex-1 min-w-0">
        <div class="flex items-baseline justify-between mb-12 md:mb-16">
          <h2
            class="text-[24px] md:text-[28px] tracking-[-1.5px] uppercase text-[#000000] font-[family-name:var(--font-space-grotesk)]"
            style="font-weight: 700;"
          >
            Latest Sessions
          </h2>
          <a
            class="text-[10px] tracking-[2px] uppercase text-[#777777] hover:text-[#000000] no-underline transition-colors duration-300 flex items-center gap-2 font-[family-name:var(--font-space-grotesk)]"
            href="/sessions"
          >
            All
            <span aria-hidden="true">→</span>
          </a>
        </div>
        <SessionList sessions={sessions} variant="compact" />
      </section>

      <HomeThoughts entries={latestThoughts} />
    </div>

    <Marquee text={config.marqueeText} />
  </div>
</SiteLayout>
