---
import SiteLayout from '../../layouts/SiteLayout.astro';
import SessionTapeContent from '@/components/astro/SessionTapeContent.astro';
import { getSessionBySlug, getAllSessionSlugs, getSiteConfig } from '@/lib/sanity/fetch';
import { sessionTapeJsonLd } from '@/lib/seo/jsonld';
import { pickOgImage } from '@/lib/seo/og-image';
import { countWords } from '@/lib/seo/word-count';

export async function getStaticPaths() {
  const slugs = await getAllSessionSlugs();
  return slugs.map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const [session, config] = await Promise.all([
  getSessionBySlug(slug!),
  getSiteConfig(),
]);

if (!session) {
  return Astro.redirect('/404');
}

const nl = config.newsletter ?? {};
const inlineNewsletterCopy = {
  heading: nl.inlineHeading,
  description: nl.inlineDescription,
  buttonLabel: nl.buttonLabel,
  placeholder: nl.placeholder,
  successMessage: nl.successMessage,
  alreadySubscribedMessage: nl.alreadySubscribedMessage,
  unsubscribeLabel: nl.unsubscribeLabel,
  unsubscribeConfirmedMessage: nl.unsubscribeConfirmedMessage,
  errorMessage: nl.errorMessage,
};

const description = session.subtitle || session.excerpt || `${session.title} — a session tape by ${config.author}`;
const canonical = `/sessions/${slug}`;

const og = pickOgImage(session.featuredImage?.url, config);
const wordCount = countWords(session.content);
const jsonLd = sessionTapeJsonLd(session, config, { ogImageUrl: og?.url, wordCount });
---

<SiteLayout
  articleAuthor={config.author}
  articleModifiedTime={session.dateModified ?? session.date}
  articlePublishedTime={session.date}
  canonicalUrl={canonical}
  description={description}
  jsonLd={jsonLd}
  ogImage={og?.url}
  ogImageAlt={session.featuredImage?.alt ?? session.title}
  ogImageHeight={og?.height}
  ogImageWidth={og?.width}
  ogType="article"
  title={session.title}
>
  <SessionTapeContent newsletterCopy={inlineNewsletterCopy} session={session} />
</SiteLayout>
