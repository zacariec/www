---
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '../app/globals.css';
import { ClientRouter } from 'astro:transitions';
import { getSiteConfig } from '@/lib/sanity/fetch';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogImageAlt?: string;
  ogType?: string;
  canonicalUrl?: string;
  jsonLd?: object;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
}

const {
  title,
  description: descriptionProp,
  ogImage,
  ogImageWidth = 1200,
  ogImageHeight = 630,
  ogImageAlt,
  ogType = 'website',
  canonicalUrl,
  jsonLd,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
} = Astro.props;

const config = await getSiteConfig();

const siteUrl = config.siteUrl ? config.siteUrl.replace(/\/$/, '') : '';
function toAbsolute(url: string | undefined): string | undefined {
  if (!url) return undefined;
  if (/^https?:\/\//i.test(url)) return url;
  if (url.startsWith('/')) return siteUrl ? `${siteUrl}${url}` : undefined;
  return siteUrl ? `${siteUrl}/${url}` : undefined;
}

const description = descriptionProp ?? config.siteDescription ?? 'Code, systems, and unfiltered thinking.';
const siteName = config.siteName || 'zcarr.dev';
const pageTitle = title ? `${title} | ${siteName}` : `${siteName} \u2014 Code, Systems & Noise`;

const absoluteCanonical = toAbsolute(canonicalUrl) ?? (siteUrl ? `${siteUrl}${Astro.url.pathname}` : undefined);
const absoluteOgImage = toAbsolute(ogImage);
const twitterHandle = config.twitterHandle;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {absoluteCanonical && <meta property="og:url" content={absoluteCanonical} />}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    {absoluteOgImage && <meta property="og:image" content={absoluteOgImage} />}
    {absoluteOgImage && <meta property="og:image:secure_url" content={absoluteOgImage} />}
    {absoluteOgImage && <meta property="og:image:width" content={String(ogImageWidth)} />}
    {absoluteOgImage && <meta property="og:image:height" content={String(ogImageHeight)} />}
    {absoluteOgImage && ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}

    {ogType === 'article' && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === 'article' && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogType === 'article' && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    {ogType === 'article' && <meta property="article:section" content="Writing" />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {absoluteOgImage && <meta name="twitter:image" content={absoluteOgImage} />}
    {twitterHandle && <meta name="twitter:site" content={twitterHandle} />}
    {twitterHandle && <meta name="twitter:creator" content={twitterHandle} />}

    <!-- Apple -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content={siteName} />

    {absoluteCanonical && <link rel="canonical" href={absoluteCanonical} />}

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <ClientRouter />
  </head>
  <body class="min-h-screen bg-[#f9f9f7] font-[family-name:var(--font-space-grotesk)]">
    <slot />
  </body>

  <script>
    // Re-apply blob cursor class after Astro view transitions
    function ensureBlobCursor() {
      if (document.querySelector('[data-blob-cursor]')) {
        document.documentElement.classList.add('blob-cursor-active');
      }
    }
    document.addEventListener('astro:after-swap', ensureBlobCursor);
    document.addEventListener('astro:page-load', ensureBlobCursor);
  </script>

  <script>
    // Reveal-on-scroll helper for [data-reveal] elements
    import '@/scripts/reveal';
  </script>

  <style is:global>
    /* Disable ALL default view transition animations — our canvas handles it */
    ::view-transition-old(*),
    ::view-transition-new(*),
    ::view-transition-group(*),
    ::view-transition-image-pair(*) {
      animation: none !important;
      mix-blend-mode: normal !important;
    }
    ::view-transition-old(*) {
      display: none !important;
    }
  </style>
</html>
