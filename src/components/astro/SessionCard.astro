---
interface Props {
  slug: string;
  title: string;
  subtitle: string;
  date: string;
  readingTime: string;
  commentCount?: number;
  variant?: 'compact' | 'full';
}

const { slug, title, subtitle, date, readingTime, commentCount, variant = 'compact' } = Astro.props;

const formattedDate =
  variant === 'full'
    ? new Date(date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
    : new Date(date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

const containerPadding = variant === 'full' ? 'py-8 md:py-14' : 'py-8 md:py-12';
const dateMinWidth = variant === 'full' ? 'md:min-w-[200px]' : 'md:min-w-[180px]';
const titleClass =
  variant === 'full'
    ? 'text-[24px] md:text-[36px] tracking-[-2px]'
    : 'text-[22px] md:text-[30px] tracking-[-1.5px]';
const subtitleHide = variant === 'compact' ? 'hidden md:block' : '';
---

<a class="group block no-underline" href={`/sessions/${slug}`}>
  <div class={`${containerPadding} flex flex-col md:flex-row md:items-start gap-3 md:gap-16`}>
    <div class={`flex items-center gap-3 ${dateMinWidth} shrink-0`}>
      <span class="text-[10px] tracking-[1.5px] uppercase text-[#777777] font-[family-name:var(--font-space-grotesk)]">
        {formattedDate}
      </span>
      {variant === 'compact' && (
        <>
          <span class="text-[10px] text-[#c6c6c6]">/</span>
          <span class="text-[10px] tracking-[1.5px] uppercase text-[#777777] font-[family-name:var(--font-space-grotesk)]">
            {readingTime}
          </span>
        </>
      )}
    </div>
    <div class="flex-1">
      <h3
        class={`${titleClass} text-[#000000] group-hover:text-[#777777] transition-colors duration-500 mb-2 md:mb-3 font-[family-name:var(--font-space-grotesk)]`}
        style="font-weight: 700; line-height: 1.05;"
      >
        {title}
      </h3>
      <p
        class={`text-[13px] md:text-[14px] text-[#777777] max-w-[500px] font-[family-name:var(--font-inter)] ${subtitleHide}`}
        style="line-height: 1.6;"
      >
        {subtitle}
      </p>
      {variant === 'full' && (
        <div class="flex items-center gap-3 mt-4">
          <span class="text-[10px] tracking-[1px] uppercase text-[#c6c6c6] font-[family-name:var(--font-space-grotesk)]">
            {readingTime}
          </span>
          {commentCount !== undefined && (
            <>
              <span class="text-[10px] text-[#e2e3e1]">·</span>
              <span class="text-[10px] tracking-[1px] uppercase text-[#c6c6c6] font-[family-name:var(--font-space-grotesk)]">
                {commentCount} comments
              </span>
            </>
          )}
        </div>
      )}
    </div>
    <div class="hidden md:flex items-center self-center">
      <span
        class="text-[#c6c6c6] group-hover:text-[#000000] group-hover:translate-x-1 transition-all duration-500 text-xl"
        aria-hidden="true"
      >
        →
      </span>
    </div>
  </div>
</a>
