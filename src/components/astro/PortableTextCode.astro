---
// Custom serializer for the `code` block inside PortableText content.
// Uses shiki for build-time syntax highlighting — themes are inlined as HTML,
// zero client-side JS is shipped for syntax highlighting.
//
// Shiki lazy-imports language grammars at runtime. That works fine during a
// static build, but the preview route (`prerender = false`) runs inside the
// Cloudflare Workers runtime, where dynamic node_modules resolution is flaky.
// We catch any failure and fall back to a plain <pre><code> — the preview
// never 500s just because a grammar didn't load.
import { codeToHtml } from 'shiki';

interface CodeNode {
  _type: 'code';
  _key?: string;
  code: string;
  language?: string;
  filename?: string;
  highlightedLines?: number[];
}

interface Props {
  node: CodeNode;
  index: number;
  isInline: boolean;
}

const { node } = Astro.props;
const language = node.language || 'text';
const code = node.code ?? '';

// Languages we've wired into the Sanity schema. Anything outside this list
// falls back to plain text so shiki doesn't throw on missing grammar.
const supportedLanguages = new Set([
  'text',
  'bash',
  'css',
  'diff',
  'groq',
  'html',
  'javascript',
  'json',
  'liquid',
  'markdown',
  'python',
  'sql',
  'tsx',
  'typescript',
  'yaml',
]);
const lang = supportedLanguages.has(language) ? language : 'text';

function escapeHtml(input: string): string {
  return input
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

let html: string;
try {
  html = await codeToHtml(code, {
    lang,
    theme: 'tokyo-night',
  });
} catch (err) {
  // Preview runtime (workerd) can fail to pull a grammar — don't crash the
  // route. Log to the worker console and render plain, un-highlighted code.
  console.warn('[PortableTextCode] shiki failed, falling back:', err instanceof Error ? err.message : err);
  html = `<pre class="shiki" style="background-color:#1a1b26;color:#a9b1d6"><code>${escapeHtml(code)}</code></pre>`;
}
---

<figure class="my-8 md:my-12">
  {node.filename && (
    <figcaption
      class="text-[9px] tracking-[1.5px] uppercase text-[#777777] mb-2 font-[family-name:var(--font-space-grotesk)]"
    >
      {node.filename}
    </figcaption>
  )}
  <div
    class="rounded-md overflow-hidden text-[13px] md:text-[14px] font-[family-name:var(--font-jetbrains-mono,monospace)]"
    set:html={html}
  />
</figure>

<style is:global>
  /* shiki ships inline styles via `style="..."`; keep its background but
     force our layout rules so the pre plays nicely with the article column. */
  figure > .shiki,
  figure > div > pre.shiki {
    padding: 1rem 1.25rem;
    line-height: 1.7;
    overflow-x: auto;
  }
</style>
