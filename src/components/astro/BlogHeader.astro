---
import Reveal from './Reveal.astro';
---

<Reveal>
  <p class="text-[10px] tracking-[3px] uppercase text-[#777777] mb-6 md:mb-8 font-[family-name:var(--font-space-grotesk)]">
    Long-Form
  </p>
</Reveal>
<Reveal variant="text">
  <h1
    class="text-[clamp(48px,10vw,100px)] text-[#000000] tracking-[-0.05em] font-[family-name:var(--font-space-grotesk)]"
    style="font-weight: 700; line-height: 0.9;"
  >
    WRITING<span class="text-[#c6c6c6]">.</span>
  </h1>
</Reveal>
