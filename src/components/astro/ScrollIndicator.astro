---
// Animated scroll-down indicator pinned to the bottom of a section.
---

<div class="scroll-indicator absolute bottom-6 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-2">
  <div class="scroll-indicator-bar w-px h-8 bg-[#c6c6c6]"></div>
</div>

<style>
  .scroll-indicator {
    opacity: 0;
    animation: scroll-indicator-fade 600ms cubic-bezier(0.25, 0.1, 0.25, 1) 1.2s forwards;
  }
  @keyframes scroll-indicator-fade {
    to { opacity: 1; }
  }
  @keyframes scroll-indicator-pulse {
    0%, 100% { transform: scaleY(1); }
    50%      { transform: scaleY(0.5); }
  }
  .scroll-indicator-bar {
    transform-origin: top;
    animation: scroll-indicator-pulse 2s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-indicator { opacity: 1; animation: none; }
    .scroll-indicator-bar { animation: none; }
  }
</style>
