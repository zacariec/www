---
// Custom serializer for block.style === "h2" in session-tape content.
// Kept close to the body type scale but with real heading weight and
// enough breathing room to separate sections.
---

<h2
  class="mt-12 md:mt-16 mb-4 md:mb-6 text-[clamp(22px,3.5vw,32px)] text-[#000000] tracking-[-0.02em] font-[family-name:var(--font-space-grotesk)]"
  style="font-weight: 700; line-height: 1.2;"
>
  <slot />
</h2>
