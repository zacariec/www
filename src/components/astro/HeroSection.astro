---
import Reveal from './Reveal.astro';
import ScrollIndicator from './ScrollIndicator.astro';

interface Props {
  subtitle?: string;
  heading?: string[];
  description?: string;
}

const {
  subtitle = 'Journal \u2014 Est. 2024',
  heading = ['THOUGHTS,', 'UNFILTERED.'],
  description = 'Long-form thinking, brain dumps, and the things I can\u2019t stop turning over.',
} = Astro.props;
---

<section class="min-h-[90vh] md:min-h-screen flex flex-col justify-end px-5 md:px-16 pb-12 md:pb-20 relative">
  <div
    class="absolute inset-0 opacity-[0.02] pointer-events-none"
    style="background-image: linear-gradient(rgba(0,0,0,1) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,1) 1px, transparent 1px); background-size: 60px 60px;"
  />

  <div class="relative">
    <Reveal delay={200}>
      <p class="text-[10px] md:text-[11px] tracking-[3px] uppercase text-[#777777] mb-6 md:mb-8 font-[family-name:var(--font-space-grotesk)]">
        {subtitle}
      </p>
    </Reveal>

    {heading.map((line, i) => {
      const isLast = i === heading.length - 1;
      const stripped = isLast ? line.replace(/\.$/, '') : line;
      return (
        <Reveal variant="text" delay={i * 100}>
          <h1
            class="text-[clamp(44px,12vw,140px)] text-[#000000] tracking-[-0.05em] font-[family-name:var(--font-space-grotesk)]"
            style="font-weight: 700; line-height: 0.88;"
          >
            {stripped}
            {isLast && <span class="text-[#c6c6c6]">.</span>}
          </h1>
        </Reveal>
      );
    })}

    <div class="mt-10 md:mt-16 flex flex-col md:flex-row md:items-end justify-between gap-8">
      <Reveal delay={400}>
        <p
          class="text-[15px] md:text-[18px] text-[#777777] max-w-[440px] font-[family-name:var(--font-inter)]"
          style="font-weight: 300; line-height: 1.7;"
        >
          {description}
        </p>
      </Reveal>
    </div>
  </div>

  <ScrollIndicator />
</section>
