---
import HorizontalLine from './HorizontalLine.astro';
import SessionCard from './SessionCard.astro';
import Reveal from './Reveal.astro';

interface Session {
  slug: string;
  title: string;
  subtitle: string;
  date: string;
  readingTime: string;
  commentCount?: number;
}

interface Props {
  sessions: Session[];
  variant?: 'compact' | 'full';
}

const { sessions, variant = 'compact' } = Astro.props;
---

<div>
  {sessions.map((session, i) => (
    <Reveal delay={i * 80}>
      <HorizontalLine />
      <SessionCard
        commentCount={session.commentCount}
        date={session.date}
        readingTime={session.readingTime}
        slug={session.slug}
        subtitle={session.subtitle}
        title={session.title}
        variant={variant}
      />
    </Reveal>
  ))}
  <HorizontalLine />
</div>
